# ═══════════════════════════════════════════════════════════════════════════════
# Telclaude Docker Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# CREDENTIAL MANAGEMENT:
#   Most credentials now live in the vault sidecar.
#   After first startup, import existing credentials:
#     docker exec -it telclaude telclaude vault import-secrets
#     docker exec -it telclaude telclaude vault import-anthropic
#
#   Or add credentials directly:
#     docker exec -it telclaude telclaude vault add secret telegram-bot-token
#     docker exec -it telclaude telclaude vault add http api.anthropic.com --type api-key --header x-api-key
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────────────

# Path to your projects folder (where Claude will work)
WORKSPACE_PATH=/mnt/c/Users/YourName/Projects

# TOTP encryption key for 2FA secrets
# Generate with: openssl rand -base64 32
# IMPORTANT: Keep this safe! If lost, all 2FA secrets become unrecoverable.
TOTP_ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_-base64_32

# Vault encryption key for credential storage
# Generate with: openssl rand -base64 32
# IMPORTANT: Keep this safe! If lost, all stored credentials become unrecoverable.
VAULT_ENCRYPTION_KEY=GENERATE_WITH_openssl_rand_-base64_32

# ─────────────────────────────────────────────────────────────────────────────────
# Credentials (env var fallbacks — vault preferred)
#
# These are optional when vault is configured. The relay checks:
#   1. Vault (highest priority)
#   2. Config file
#   3. Environment variable (this file)
# ─────────────────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
# Preferred: `telclaude vault add secret telegram-bot-token`
# TELEGRAM_BOT_TOKEN=your_bot_token_here

# Anthropic API key (alternative to claude login)
# Preferred: `telclaude vault add http api.anthropic.com --type api-key --header x-api-key`
# ANTHROPIC_API_KEY=sk-ant-...

# Internal token used by runtime workers to access the Anthropic proxy
# REQUIRED for Docker runtime -> relay access (this guards /v1/anthropic-proxy)
# Generate with: openssl rand -hex 32
ANTHROPIC_PROXY_TOKEN=GENERATE_WITH_openssl_rand_-hex_32

# OpenAI Codex relay-proxy HMAC signing secret (for /codex work units on the NUC).
# RELAY ONLY — never set this on runtime containers. The relay mints short-lived,
# peer-bound per-job tokens; runtime workers never hold this secret. Optional: leave
# blank to disable /codex relay brokering (codex then has no inference auth).
# The durable ChatGPT/Codex subscription OAuth lives in the vault, NOT here, at
# target `openai-codex-oauth` (see: telclaude vault add secret openai-codex-oauth).
# Generate with: openssl rand -hex 32
TELCLAUDE_OPENAI_CODEX_PROXY_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────────
# RPC Authentication (Ed25519 bidirectional asymmetric keys)
#
# Two keypairs per scope: agent keypair + relay keypair.
# Each side owns its own private key — compromise of one side cannot
# forge messages in the other direction.
#
# After initial auth, agents exchange for short-lived session tokens (v3).
# ─────────────────────────────────────────────────────────────────────────────────

# Telegram RPC: two keypairs for bidirectional auth
# Generate all 4 keys: telclaude keygen telegram
# Agent keypair (agent signs → relay verifies):
TELEGRAM_RPC_AGENT_PRIVATE_KEY=GENERATE_WITH_telclaude_keygen_telegram
TELEGRAM_RPC_AGENT_PUBLIC_KEY=GENERATE_WITH_telclaude_keygen_telegram
# Relay keypair (relay signs → agent verifies):
TELEGRAM_RPC_RELAY_PRIVATE_KEY=GENERATE_WITH_telclaude_keygen_telegram
TELEGRAM_RPC_RELAY_PUBLIC_KEY=GENERATE_WITH_telclaude_keygen_telegram

# Git proxy session token secret (shared between relay + agent for HMAC session tokens)
# Generate with: openssl rand -hex 32
TELCLAUDE_GIT_PROXY_SECRET=GENERATE_WITH_openssl_rand_-hex_32

# Social RPC: two keypairs for bidirectional auth (all social service agents)
# Generate all 4 keys: telclaude keygen social
# Agent keypair (agent signs → relay verifies):
SOCIAL_RPC_AGENT_PRIVATE_KEY=GENERATE_WITH_telclaude_keygen_social
SOCIAL_RPC_AGENT_PUBLIC_KEY=GENERATE_WITH_telclaude_keygen_social
# Relay keypair (relay signs → agent verifies):
SOCIAL_RPC_RELAY_PRIVATE_KEY=GENERATE_WITH_telclaude_keygen_social
SOCIAL_RPC_RELAY_PUBLIC_KEY=GENERATE_WITH_telclaude_keygen_social

# ─────────────────────────────────────────────────────────────────────────────────
# Configuration Files
#
# Telclaude uses a two-file config split for Docker:
#   telclaude.json         — Policy config (providers, network, rate limits).
#                            Mounted to ALL containers (relay + contained runtimes).
#   telclaude-private.json — Relay-only overrides (allowedChats, permissions,
#                            deprecated secret fields). Mounted to relay ONLY.
#
# The relay deep-merges private on top of policy. Contained runtimes only see policy.
# This prevents secrets/PII from leaking to runtime containers.
#
# For single-file setups: put everything in telclaude.json and skip the
# private file. The relay will work fine without TELCLAUDE_PRIVATE_CONFIG.
# ─────────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────────────

# Log level: debug, info, warn, error
TELCLAUDE_LOG_LEVEL=info

# Network firewall (REQUIRED for Docker mode; LLM/persona runtime is Hermes-contained)
# Set to 1 to enable, requires --cap-add=NET_ADMIN
# SECURITY: Without firewall, Bash commands can reach arbitrary endpoints including cloud metadata
TELCLAUDE_FIREWALL=1

# Firewall DNS retry settings (internal host resolution)
# TELCLAUDE_FIREWALL_RETRY_COUNT=10
# TELCLAUDE_FIREWALL_RETRY_DELAY=2

# IPv6 fail-closed behavior
# TELCLAUDE_IPV6_FAIL_CLOSED=1

# TESTING ONLY: Bypass firewall requirement (NEVER use in production!)
# TELCLAUDE_ACCEPT_NO_FIREWALL=1

# Internal RPC allowlist for firewall (comma-separated service hostnames).
# TELCLAUDE_INTERNAL_HOSTS=telclaude,google-services

# ─────────────────────────────────────────────────────────────────────────────────
# Hermes private runtime live run
# ─────────────────────────────────────────────────────────────────────────────────
#
# Use only with docker/docker-compose.hermes.yml. The image below is pinned to
# the official Hermes v2026.5.29 / v0.15.1 manifest digest, verified with:
#   docker buildx imagetools inspect nousresearch/hermes-agent:v2026.5.29
#
# The API key is an ephemeral relay-to-Hermes bearer token; generate a fresh
# value for each compose up or deployment rotation and never commit a real value.
#
# TELCLAUDE_HERMES_IMAGE=nousresearch/hermes-agent@sha256:192a40783e9227b5f162b76af4d133050557adebd46e1c9cb40cb79a1317a9f7
# TELCLAUDE_HERMES_API_SERVER_KEY=GENERATE_PER_COMPOSE_UP_WITH_openssl_rand_-base64_48
# TELCLAUDE_HERMES_SOCIAL_API_SERVER_KEY=GENERATE_PER_COMPOSE_UP_WITH_openssl_rand_-base64_48
# TELCLAUDE_HERMES_MCP_RELAY_TOKEN=GENERATE_PER_COMPOSE_UP_WITH_openssl_rand_-base64_48
# TELCLAUDE_HERMES_RELAY_SUBNET=192.0.2.0/24
# TELCLAUDE_HERMES_SOCIAL_RELAY_SUBNET=192.0.3.0/24
# TELCLAUDE_HERMES_RELAY_IP=192.0.2.10
# TELCLAUDE_HERMES_SOCIAL_RELAY_IP=192.0.3.10
# TELCLAUDE_HERMES_CONTAINED_IP=192.0.2.11
# TELCLAUDE_HERMES_SOCIAL_IP=192.0.3.11
# TELCLAUDE_HERMES_LIVE_MCP_ENABLED=0
# TELCLAUDE_HERMES_LIVE_MCP_HOST=telclaude
# TELCLAUDE_HERMES_LIVE_MCP_PORT=8793
# TELCLAUDE_HERMES_LIVE_MCP_PATH=/mcp
# TELCLAUDE_HERMES_LIVE_MCP_NETWORK=telclaude-hermes-private
# TELCLAUDE_HERMES_LIVE_MCP_ADDITIONAL_BINDS=192.0.3.10@telclaude-hermes-social
# TELCLAUDE_HERMES_LIVE_MCP_ALLOWED_PEERS=192.0.2.11,192.0.3.11
# TELCLAUDE_HERMES_SERVED_MCP_URL=http://telclaude:8793/mcp
# TELCLAUDE_HERMES_SERVED_MCP_AUTH="Authorization: Bearer PRIVATE_PROBE_TOKEN"
# TELCLAUDE_HERMES_SERVED_MCP_OFF_DOMAIN_PEER_AUTH="Authorization: Bearer OFF_DOMAIN_PROBE_TOKEN"
# TELCLAUDE_HERMES_SERVED_MCP_OFF_DOMAIN_CONTAINER=tc-hermes-social-sentinel
# TELCLAUDE_HERMES_SERVED_MCP_OFF_DOMAIN_PEER_IP=192.0.3.11
# TELCLAUDE_HERMES_LIVE_MCP_ADMIN_ENABLED=0
# TELCLAUDE_HERMES_LIVE_MCP_ADMIN_SOCKET=/run/telclaude/hermes-live-mcp-admin.sock
# OPERATOR_RPC_AGENT_PUBLIC_KEY=relay_verifies_operator_cli_with_this_public_key
# OPERATOR_RPC_RELAY_PRIVATE_KEY=relay_signs_operator_responses_with_this_private_key
# Keep OPERATOR_RPC_AGENT_PRIVATE_KEY on the host only; pass it to one-off operator CLI calls.
# Keep OPERATOR_RPC_RELAY_PUBLIC_KEY on the host only; use it to verify relay responses.

# ─────────────────────────────────────────────────────────────────────────────────
# API Keys (vault preferred — env vars as fallback)
# ─────────────────────────────────────────────────────────────────────────────────
# Preferred: Store in vault via `telclaude vault import-secrets`
# Fallback: Environment variables or `telclaude setup-openai` / `telclaude setup-git`
#
# OPENAI_API_KEY=sk-proj-...
# GITHUB_TOKEN=github_pat_...
# GH_TOKEN=...
