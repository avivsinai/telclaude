# ═══════════════════════════════════════════════════════════════════════════════
# Docker Build Ignore
# Excludes files from Docker build context to speed up builds
# ═══════════════════════════════════════════════════════════════════════════════

# Dependencies (will be installed in container)
node_modules/

# Build artifacts
dist/
# Host-side revision stamp: a build artifact that must NOT leak into the context.
# If copied in, a stale value survives (Dockerfile only writes .revision when it is
# missing/unknown), so the baked revision goes stale. Excluding it lets the build
# stamp the real GIT_COMMIT into a clean slate. .revision is gitignored.
.revision

# Git
.git/
.gitignore

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment files (secrets should be passed via environment variables)
.env
.env.*
!.env.example

# Test files
*.test.ts
*.spec.ts
__tests__/
coverage/

# Documentation (not needed in runtime)
*.md
!docker/README.md
!.claude/**/*.md
!.agents/skills/**/*.md
docs/
!docs/social-contract.md
!docs/architecture.md
!docs/soul.md

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Temporary files
tmp/
temp/

# Docker files (prevent recursive copies, but keep docker/ directory files)
docker-compose*.yml
/Dockerfile*
!docker/Dockerfile*

# Local development
*.local

# Telclaude local data (media cache, etc.)
.telclaude*

# Note: .claude/ directory is included (see !.claude/**/*.md exception above)
# It contains skills (SKILL.md files) needed by the Claude Agent SDK
