# ═══════════════════════════════════════════════════════════════════════════════
# Telclaude Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# Required
# ─────────────────────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ─────────────────────────────────────────────────────────────────────────────────
# Optional
# ─────────────────────────────────────────────────────────────────────────────────

# Anthropic API key (alternative to claude login)
# If not set, you'll need to run `claude login` first
# ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────────────────────────────────────────────────────────
# API Keys (tier-based sandbox exposure)
# ─────────────────────────────────────────────────────────────────────────────────
# Keys are automatically exposed to sandbox for WRITE_LOCAL and FULL_ACCESS tiers.
# READ_ONLY tier never gets keys exposed.
#
# Configure via setup commands (recommended, uses OS keychain):
#   telclaude setup-openai    # OpenAI key for image gen, TTS, transcription
#   telclaude setup-git       # GitHub token for git operations
#
# Or via environment variables:
# OPENAI_API_KEY=sk-...
# GITHUB_TOKEN=github_pat_...
# GH_TOKEN=...                # Alternative for gh CLI

# Log level: debug, info, warn, error
TELCLAUDE_LOG_LEVEL=info

# Custom config file path (default: ~/.telclaude/telclaude.json)
# TELCLAUDE_CONFIG=/path/to/config.json

# Custom data directory (default: ~/.telclaude)
# TELCLAUDE_DATA_DIR=/path/to/data

# Custom TOTP daemon socket path (default: ~/.telclaude/totp.sock)
# TELCLAUDE_TOTP_SOCKET=/path/to/totp.sock

# WhatsApp outbound bridge. The relay enforces this own-number allowlist before
# any bridge I/O.
# TELCLAUDE_WHATSAPP_SIDECAR_URL=http://whatsapp-bridge:3004
# TELCLAUDE_WHATSAPP_ALLOWED_RECIPIENTS=whatsapp:+15551234567
# WhatsApp inbound bridge events are HMAC-signed by the bridge and CL-1 wrapped
# by the relay before Hermes sees them. Operator addresses are an explicit
# inbound strong-link set and do not default to the outbound allowlist.
# TELCLAUDE_WHATSAPP_INBOUND_SECRET=
# TELCLAUDE_WHATSAPP_INBOUND_OPERATOR_ADDRESSES=whatsapp:+15551234567
# TELCLAUDE_WHATSAPP_INBOUND_PROFILE_ID=default
# TELCLAUDE_WHATSAPP_INBOUND_ACTOR_ID=operator:whatsapp
# TELCLAUDE_WHATSAPP_INBOUND_DISPLAY_NAME=

# Relay egress policy (restricted = domain allowlist; permissive = all public
# egress, metadata/RFC1918 always blocked). tc_web_fetch needs permissive;
# tc_web_search needs the Brave Search API key.
# TELCLAUDE_NETWORK_MODE=permissive
# TELCLAUDE_BRAVE_SEARCH_API_KEY=

# Recommended: prevent bootstrap race condition where scanner bots claim admin
# TELCLAUDE_ADMIN_SECRET=your-secure-random-secret
