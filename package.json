{
  "name": "telclaude",
  "version": "0.7.1",
  "description": "Secure Telegram agent bridge with LLM-based command screening, tiered permissions, and OS-level sandboxing",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "telclaude": "./bin/telclaude.js"
  },
  "files": [
    "dist",
    "bin",
    ".claude",
    "assets/skill-templates",
    "assets/dashboard-ui",
    "examples"
  ],
  "scripts": {
    "prebuild": "REV=$(git rev-parse HEAD 2>/dev/null) && printf '%.7s\\n' \"$REV\" > .revision || [ -s .revision ] || echo unknown > .revision",
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "firewall:generate": "tsx scripts/generate-firewall-domains.ts",
    "security:scan": "gitleaks detect --source . --config .gitleaks.toml",
    "prepublishOnly": "pnpm run build",
    "prepare": "pnpm run build"
  },
  "keywords": [
    "telegram",
    "claude",
    "ai",
    "bot",
    "relay",
    "cli",
    "llm",
    "anthropic",
    "security",
    "sandbox",
    "grammY",
    "agent"
  ],
  "author": {
    "name": "Aviv Sinai",
    "url": "https://github.com/avivsinai"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avivsinai/telclaude.git"
  },
  "bugs": {
    "url": "https://github.com/avivsinai/telclaude/issues"
  },
  "homepage": "https://github.com/avivsinai/telclaude#readme",
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/avivsinai"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "fastify": "5.8.5",
      "minimatch": "9.0.7",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "rollup": "4.59.0",
      "undici-types": "8.3.0",
      "vite": "7.3.2",
      "esbuild": "^0.28.1",
      "fast-uri": "^3.1.2",
      "brace-expansion@5": "^5.0.6"
    }
  },
  "os": [
    "darwin",
    "linux"
  ],
  "dependencies": {
    "@grammyjs/auto-retry": "^2.0.2",
    "@grammyjs/runner": "^2.0.3",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@steipete/summarize-core": "^0.16.3",
    "@whiskeysockets/baileys": "7.0.0-rc13",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.4.1",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "fastify": "^5.8.4",
    "googleapis": "^172.0.0",
    "grammy": "^1.43.0",
    "ip-num": "^1.5.2",
    "json5": "^2.2.3",
    "keytar": "^7.9.0",
    "oauth-callback": "^2.2.0",
    "open": "^11.0.0",
    "openai": "^6.41.0",
    "otpauth": "^9.5.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode-terminal": "^0.12.0",
    "rate-limiter-flexible": "^11.1.0",
    "shell-quote": "^1.8.4",
    "telegram-markdown-v2": "^0.0.4",
    "undici": "^8.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/shell-quote": "^1.7.5",
    "@vitest/coverage-v8": "^3.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.6"
  }
}
